<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_patient_dashboard"
    tools:context=".PatientRecentActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#0f172a" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Case #4829"
                android:textColor="#f8fafc"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>

             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ceramic Crown • Upper Right Molar"
                android:textColor="#94a3b8"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_blue"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="Active"
            android:textColor="#3b82f6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Timeline Card -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:cardBackgroundColor="#ffffff"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="24dp"
                     android:orientation="vertical">

                     <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="Case Timeline"
                        android:textColor="#0f172a"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"/>

                     <!-- Step 1: Submitted -->
                     <RelativeLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content">
                         
                         <ImageView
                             android:id="@+id/iconStep1"
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_check_circle_green"
                             app:tint="#10b981"/>

                         <View
                             android:layout_width="2dp"
                             android:layout_height="40dp"
                             android:layout_below="@id/iconStep1"
                             android:layout_alignStart="@id/iconStep1"
                             android:layout_alignEnd="@id/iconStep1"
                             android:layout_marginStart="11dp"
                             android:background="#e2e8f0"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_toEndOf="@id/iconStep1"
                             android:layout_marginStart="16dp"
                             android:orientation="vertical">

                             <LinearLayout
                                 android:layout_width="match_parent"
                                 android:layout_height="wrap_content"
                                 android:orientation="horizontal">
                                 <TextView
                                     android:layout_width="0dp"
                                     android:layout_height="wrap_content"
                                     android:layout_weight="1"
                                     android:text="Case Submitted"
                                     android:textColor="#0f172a"
                                     android:textStyle="bold"
                                     android:textSize="14sp"
                                     android:fontFamily="sans-serif"/>
                                 <TextView
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="Feb 12, 09:30 AM"
                                     android:textColor="#94a3b8"
                                     android:textSize="10sp"
                                     android:background="@drawable/bg_badge_gray_light"
                                     android:paddingHorizontal="6dp"
                                     android:paddingVertical="2dp"
                                     android:fontFamily="sans-serif"/>
                             </LinearLayout>
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:text="Initial scan and requirements received"
                                 android:textColor="#64748b"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </RelativeLayout>

                     <!-- Step 2: AI Analysis -->
                     <RelativeLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="24dp">

                         <ImageView
                             android:id="@+id/iconStep2"
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_check_circle_green"
                             app:tint="#10b981"/>
                         
                         <View
                             android:layout_width="2dp"
                             android:layout_height="40dp"
                             android:layout_below="@id/iconStep2"
                             android:layout_alignStart="@id/iconStep2"
                             android:layout_alignEnd="@id/iconStep2"
                             android:layout_marginStart="11dp"
                             android:background="#e2e8f0"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_toEndOf="@id/iconStep2"
                             android:layout_marginStart="16dp"
                             android:orientation="vertical">

                             <LinearLayout
                                 android:layout_width="match_parent"
                                 android:layout_height="wrap_content"
                                 android:orientation="horizontal">
                                 <TextView
                                     android:layout_width="0dp"
                                     android:layout_height="wrap_content"
                                     android:layout_weight="1"
                                     android:text="AI Analysis"
                                     android:textColor="#0f172a"
                                     android:textStyle="bold"
                                     android:textSize="14sp"
                                     android:fontFamily="sans-serif"/>
                                 <TextView
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="Feb 12, 10:15 AM"
                                     android:textColor="#94a3b8"
                                     android:textSize="10sp"
                                     android:background="@drawable/bg_badge_gray_light"
                                     android:paddingHorizontal="6dp"
                                     android:paddingVertical="2dp"
                                     android:fontFamily="sans-serif"/>
                             </LinearLayout>
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:text="Automated defect detection complete"
                                 android:textColor="#64748b"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </RelativeLayout>

                     <!-- Step 3: Planning & Reporting (In Progress) -->
                     <RelativeLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="24dp">

                         <ImageView
                             android:id="@+id/iconStep3"
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_circle_filled_blue"/>
                         
                         <View
                             android:layout_width="2dp"
                             android:layout_height="40dp"
                             android:layout_below="@id/iconStep3"
                             android:layout_alignStart="@id/iconStep3"
                             android:layout_alignEnd="@id/iconStep3"
                             android:layout_marginStart="11dp"
                             android:background="#e2e8f0"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_toEndOf="@id/iconStep3"
                             android:layout_marginStart="16dp"
                             android:orientation="vertical">

                             <LinearLayout
                                 android:layout_width="match_parent"
                                 android:layout_height="wrap_content"
                                 android:orientation="horizontal">
                                 <TextView
                                     android:layout_width="0dp"
                                     android:layout_height="wrap_content"
                                     android:layout_weight="1"
                                     android:text="Planning &amp; Reporting"
                                     android:textColor="#0f172a"
                                     android:textStyle="bold"
                                     android:textSize="14sp"
                                     android:fontFamily="sans-serif"/>
                                 <TextView
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="In Progress"
                                     android:textColor="#3b82f6"
                                     android:textSize="10sp"
                                     android:background="@drawable/bg_badge_gray_light"
                                     android:paddingHorizontal="6dp"
                                     android:paddingVertical="2dp"
                                     android:fontFamily="sans-serif"/>
                             </LinearLayout>
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:text="Finalizing clinical findings..."
                                 android:textColor="#64748b"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </RelativeLayout>

                     <!-- Step 4: Ready for Fitting (Pending) -->
                     <RelativeLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="24dp">

                         <ImageView
                             android:id="@+id/iconStep4"
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_circle_outline_gray"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_toEndOf="@id/iconStep4"
                             android:layout_marginStart="16dp"
                             android:orientation="vertical">

                             <LinearLayout
                                 android:layout_width="match_parent"
                                 android:layout_height="wrap_content"
                                 android:orientation="horizontal">
                                 <TextView
                                     android:layout_width="0dp"
                                     android:layout_height="wrap_content"
                                     android:layout_weight="1"
                                     android:text="Ready for Fitting"
                                     android:textColor="#94a3b8"
                                     android:textStyle="bold"
                                     android:textSize="14sp"
                                     android:fontFamily="sans-serif"/>
                                 <TextView
                                     android:layout_width="wrap_content"
                                     android:layout_height="wrap_content"
                                     android:text="Est. Feb 14"
                                     android:textColor="#94a3b8"
                                     android:textSize="10sp"
                                     android:background="@drawable/bg_badge_gray_light"
                                     android:paddingHorizontal="6dp"
                                     android:paddingVertical="2dp"
                                     android:fontFamily="sans-serif"/>
                             </LinearLayout>
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:text="Final quality check and preparation"
                                 android:textColor="#94a3b8"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </RelativeLayout>

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Buttons -->
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/btnViewAiAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_brain_ai"
                    app:tint="#a855f7"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="View AI Analysis"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#cbd5e1"
                    android:rotation="0"/>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/btnViewRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_recommendation"
                    app:tint="#3b82f6"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="View Recommendation"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#cbd5e1"
                    android:rotation="0"/>

            </androidx.appcompat.widget.LinearLayoutCompat>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0f172a"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navCases"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_cases"
                app:tint="#ffffff"/> <!-- Active context -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cases"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_reports"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Reports"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Profile"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
