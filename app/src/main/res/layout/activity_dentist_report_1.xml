<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dentist_report_1"
    tools:context=".DentistReport1Activity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#0f172a">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#ffffff" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_smile_logo"
            app:tint="#2dd4bf"
            android:layout_marginStart="8dp"/> 

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Smile AI"
            android:textColor="#f8fafc"
            android:textSize="18sp"
            android:textStyle="bold" />
        
        <ImageView
            android:id="@+id/btnNotification"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_notification"
            app:tint="#94a3b8"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu"
            app:tint="#94a3b8"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header and Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Case\nRecommendation"
                        android:textColor="#f8fafc"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Based on analysis of\n12,000+ similar cases"
                        android:textColor="#94a3b8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    
                     <LinearLayout
                        android:id="@+id/btnAdjust"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_button_white"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">
                         <ImageView
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_adjust"
                             app:tint="#334155"/>
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="Adjust\nManually"
                             android:textSize="14sp"
                             android:textColor="#334155"
                             android:gravity="center"
                             android:lineSpacingExtra="-2dp"/>
                     </LinearLayout>

                    <TextView
                        android:id="@+id/btnAccept"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_teal"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Accept\n&amp;\nPreview"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Match Confidence Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_card_match_confidence"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_margin="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_card"
                    android:backgroundTint="#24ffffff"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="80dp"
                    android:paddingBottom="80dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/tvMatchConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="98%"
                        android:textColor="#2dd4bf"
                        android:textSize="64sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Match Confidence"
                        android:textColor="#94a3b8"
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- AI Diagnostic & Treatment Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#334155"
                app:strokeWidth="1dp"
                android:layout_marginBottom="20dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Treatment Summary"
                        android:textColor="#f8fafc"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="16dp"/>
                    
                    <!-- Primary Diagnosis -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIMARY DIAGNOSIS"
                        android:textColor="#64748b"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="18dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_check_circle_outline"
                            app:tint="#2dd4bf"/>
                        <TextView
                            android:id="@+id/tvReportDeficiencyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analysis Result"
                            android:textColor="#2dd4bf"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                <!-- Recommended Treatment (Inside AI Summary Card) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECOMMENDED TREATMENT"
                    android:textColor="#64748b"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvReportGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade B"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_teal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:id="@+id/tvReportRecommendation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Restorative correction advised."
                        android:textColor="#f8fafc"
                        android:textSize="14sp"
                        android:textStyle="italic"/>
                </LinearLayout>

                <!-- AI Suggested Details -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUGGESTED RESTORATION"
                            android:textColor="#64748b"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvReportSuggestedRestoration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bridge"
                            android:textColor="#f1f5f9"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUGGESTED MATERIAL"
                            android:textColor="#64748b"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvReportSuggestedMaterial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zirconia"
                            android:textColor="#f1f5f9"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Clinical Rationale -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLINICAL RATIONALE"
                    android:textColor="#64748b"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:id="@+id/tvReportDeficiencyReasoning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Clinical Findings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:strokeColor="#334155"
                app:strokeWidth="1dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Clinical Findings"
                        android:textColor="#f8fafc"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Grid Layout for Findings -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignMargins"
                        android:rowOrderPreserved="false">

                        <!-- Missing Teeth -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivHypodontiaIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hypodontia" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportHypodontia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="None" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Discoloration -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivDiscolorationIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Staining" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportDiscoloration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Minimal" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Gums -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivGumIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gums" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportInflammation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Healthy" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Calculus -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivCalculusIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calculus" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportCalculus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Low" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Hyperdontia -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivHyperdontiaIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hyperdontia" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportHyperdontia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="None" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Symmetry -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivSymmetryIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Symmetry" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportSymmetry" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Optimal" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Golden Ratio -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                            <ImageView android:id="@+id/ivGoldenRatioIcon" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_check_circle" app:tint="#10b981"/>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="8dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Golden Ratio" android:textColor="#64748b" android:textSize="11sp"/>
                                <TextView android:id="@+id/tvReportGoldenRatio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.618 Match" android:textColor="#f1f5f9" android:textStyle="bold" android:textSize="13sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </GridLayout>

                    <TextView
                        android:id="@+id/tvReportRednessAnalysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Caries: None detected."
                        android:textColor="#94a3b8"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light"
                        android:background="#0f172a"
                        android:padding="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Risk Analysis Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRiskAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Risk Analysis"
                        android:textColor="#fca5a5"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>
                    
                    <TextView
                        android:id="@+id/tvReportRiskAnalysis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#cbd5e1"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Aesthetic Prognosis Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPrognosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aesthetic Prognosis"
                        android:textColor="#86efac"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>
                    
                    <TextView
                        android:id="@+id/tvReportAestheticPrognosis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#cbd5e1"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Placement Strategy Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Placement Strategy"
                        android:textColor="#7dd3fc"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginBottom="10dp"/>
                    
                    <TextView
                        android:id="@+id/tvReportPlacementStrategy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="..."
                        android:textColor="#cbd5e1"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recommendation Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended\nShape"
                        android:textColor="#2dd4bf"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvReportRecommendedShape"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ovoid-Tapering Hybrid"
                        android:textColor="#2dd4bf"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended\nShade"
                        android:textColor="#3b82f6"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvReportRecommendedShade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A2 Body / A1 Incisal"
                        android:textColor="#3b82f6"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Planning Parameters -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planning Parameters"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Length" android:textColor="#94a3b8"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10.5 mm" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
