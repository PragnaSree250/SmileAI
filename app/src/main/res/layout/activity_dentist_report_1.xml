<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dentist_report_1"
    tools:context=".DentistReport1Activity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#0f172a">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                android:tint="#ffffff" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_smile_logo"
            app:tint="#2dd4bf"
            android:layout_marginStart="8dp"/> 

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Smile AI"
            android:textColor="#f8fafc"
            android:textSize="18sp"
            android:textStyle="bold" />
        
        <ImageView
            android:id="@+id/btnNotification"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_notification"
            app:tint="#94a3b8"
            android:layout_marginEnd="16dp"/>

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_menu"
            app:tint="#94a3b8"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header and Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Case\nRecommendation"
                        android:textColor="#f8fafc"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Based on analysis of\n12,000+ similar cases"
                        android:textColor="#94a3b8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">
                    
                     <LinearLayout
                        android:id="@+id/btnAdjust"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_button_white"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">
                         <ImageView
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_adjust"
                             app:tint="#334155"/>
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="Adjust\nManually"
                             android:textSize="14sp"
                             android:textColor="#334155"
                             android:gravity="center"
                             android:lineSpacingExtra="-2dp"/>
                     </LinearLayout>

                    <TextView
                        android:id="@+id/btnAccept"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_teal"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Accept\n&amp;\nPreview"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Match Confidence Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">
                
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:background="@drawable/bg_card_match_confidence"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_margin="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_surface_card"
                    android:backgroundTint="#24ffffff"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="80dp"
                    android:paddingBottom="80dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/tvMatchConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="98%"
                        android:textColor="#2dd4bf"
                        android:textSize="64sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Match Confidence"
                        android:textColor="#94a3b8"
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- AI Diagnostic & Treatment Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Diagnostic &amp; Treatment Summary"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="16dp"/>
                
                <!-- Primary Diagnosis -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRIMARY DIAGNOSIS"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle_outline"
                        app:tint="#2dd4bf"/>
                    <TextView
                        android:id="@+id/tvReportDeficiencyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Space Deficiency Resolved"
                        android:textColor="#2dd4bf"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

                <!-- Recommended Treatment -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RECOMMENDED TREATMENT"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvReportGrade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade B"
                        android:textColor="#ffffff"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_teal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:id="@+id/tvReportRecommendation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Minor restorative correction advised."
                        android:textColor="#f8fafc"
                        android:textSize="14sp"
                        android:textStyle="italic"/>
                </LinearLayout>

                <!-- AI Suggested Treatment -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUGGESTED RESTORATION"
                            android:textColor="#94a3b8"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:id="@+id/tvReportSuggestedRestoration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textColor="#f8fafc"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUGGESTED MATERIAL"
                            android:textColor="#94a3b8"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>
                        <TextView
                            android:id="@+id/tvReportSuggestedMaterial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textColor="#f8fafc"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Clinical Rationale -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLINICAL RATIONALE"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvReportDeficiencyReasoning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The multi-unit Bridge proposed plan restores occlusal vertical dimension and prevents further shifting of the #18 and #20 abutments."
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Clinical Findings Card (Moved from input screens) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Clinical Findings"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                
                <!-- Hyperdontia -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Hyperdontia" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportHyperdontia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Aesthetic Symmetry -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Aesthetic Symmetry" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportSymmetry" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Golden Ratio -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Golden Ratio" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportGoldenRatio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Hypodontia -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Hypodontia" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportHypodontia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Discoloration -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Discoloration" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportDiscoloration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Inflammation -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Gingivitis" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportInflammation" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Calculus -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Calculus" android:textColor="#94a3b8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvReportCalculus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvReportRednessAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Redness Analysis: ..."
                    android:textColor="#cbd5e1"
                    android:textSize="12sp"
                    android:fontStyle="italic"
                    android:background="#1e293b"
                    android:padding="8dp"/>
            </LinearLayout>

            <!-- Risk Analysis Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#1aff0000"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Risk Analysis"
                    android:textColor="#fca5a5"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                
                <TextView
                    android:id="@+id/tvReportRiskAnalysis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading analysis..."
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Aesthetic Prognosis Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#1a00ff00"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aesthetic Prognosis"
                    android:textColor="#86efac"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                
                <TextView
                    android:id="@+id/tvReportAestheticPrognosis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading prognosis..."
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Placement Strategy Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#1a0000ff"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Placement Strategy"
                    android:textColor="#7dd3fc"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>
                
                <TextView
                    android:id="@+id/tvReportPlacementStrategy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading strategy..."
                    android:textColor="#cbd5e1"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Recommendation Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended\nShape"
                        android:textColor="#2dd4bf"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ovoid-Tapering Hybrid"
                        android:textColor="#2dd4bf"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_surface_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recommended\nShade"
                        android:textColor="#3b82f6"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A2 Body / A1 Incisal"
                        android:textColor="#3b82f6"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Planning Parameters -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planning Parameters"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Length" android:textColor="#94a3b8"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10.5 mm" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
