<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f172a"
    tools:context=".PatientBrushingTimerActivity">

    <!-- Top Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#f8fafc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Brushing Timer"
            android:textColor="#f8fafc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

        <View android:layout_width="24dp" android:layout_height="24dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Streak Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_orange"
                android:backgroundTint="#ffedd5"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_sparkles_blue"
                    app:tint="#f97316"/>
                    
                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Day Streak!"
                    android:textColor="#c2410c"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Healthy Smile, Healthy Life"
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:layout_marginBottom="32dp"/>

            <!-- Timer Circle Container -->
            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_marginBottom="32dp">

                <ProgressBar
                    android:id="@+id/timerProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:indeterminate="false"
                    android:max="120"
                    android:progress="120"
                    android:progressDrawable="@drawable/bg_circular_progress"
                    android:rotation="-90" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02:00"
                        android:textColor="#f8fafc"
                        android:textSize="48sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTimerLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REMAINING"
                        android:textColor="#64748b"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
            </FrameLayout>

            <!-- Quadrant Visual Guide -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp"
                android:gravity="center">
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <View
                        android:id="@+id/viewQuad1"
                        android:layout_width="40dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:layout_margin="4dp"/>
                        
                    <View
                        android:id="@+id/viewQuad2"
                        android:layout_width="40dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:layout_margin="4dp"/>
                </LinearLayout>
                
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    
                    <View
                        android:id="@+id/viewQuad3"
                        android:layout_width="40dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:layout_margin="4dp"/>
                        
                    <View
                        android:id="@+id/viewQuad4"
                        android:layout_width="40dp"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_card_semi_transparent"
                        android:layout_margin="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvQuadrantLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UPPER RIGHT"
                    android:textColor="#38bdf8"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:visibility="invisible"/>
            </LinearLayout>

            <!-- Tip Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_pill"
                        app:tint="#38bdf8"
                        android:background="@drawable/bg_icon_circle_dark"
                        android:backgroundTint="#0f172a"
                        android:padding="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Brushing Tip"
                            android:textColor="#38bdf8"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tvBrushingTip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start with the outer surfaces of your top teeth."
                            android:textColor="#f8fafc"
                            android:textSize="15sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Controls -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textAllCaps="false"
                    android:textColor="#f8fafc"
                    android:backgroundTint="#334155"
                    app:cornerRadius="16dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnStartStop"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="2"
                    android:text="Start Brushing"
                    android:textAllCaps="false"
                    android:textColor="#ffffff"
                    android:backgroundTint="#3b82f6"
                    app:cornerRadius="16dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
