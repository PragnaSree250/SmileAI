<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".DentistNewCase1Activity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:text="New Case Entry"
            android:textColor="#94a3b8"
            android:textSize="16sp" />
        
        <Space android:layout_width="60dp" android:layout_height="24dp" />
    </LinearLayout>

    <!-- Progress Steps (Standardized 4 Steps) -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="24dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <!-- Step 1: Active -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:gravity="center"
            android:text="1"
            android:textColor="#10b981"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#334155" />

        <!-- Step 2: Inactive -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_input_box"
            android:gravity="center"
            android:text="2"
            android:textColor="#64748b" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#334155" />

        <!-- Step 3: Inactive -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_input_box"
            android:gravity="center"
            android:text="3"
            android:textColor="#64748b" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#334155" />

        <!-- Step 4: Inactive -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_input_box"
            android:gravity="center"
            android:text="4"
            android:textColor="#64748b" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:fontFamily="sans-serif-medium"
        android:text="Patient Details"
        android:textColor="#f8fafc"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressContainer" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/footerParams"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Clinical Patient ID" android:textColor="#ffffff" android:textStyle="bold" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/etPatientId" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:background="@drawable/bg_input_box_highlight" android:hint="e.g. P1001" android:minHeight="56dp" android:padding="16dp" android:textColor="#ffffff" android:textColorHint="#cbd5e1" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Name" android:textColor="#ffffff" android:textStyle="bold" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/etFullName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:background="@drawable/bg_input_box_highlight" android:hint="e.g. Jane Doe" android:minHeight="56dp" android:padding="16dp" android:textColor="#ffffff" android:textColorHint="#cbd5e1" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date of Birth" android:textColor="#ffffff" android:textStyle="bold" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/etDob" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:background="@drawable/bg_input_box_highlight" android:clickable="true" android:drawableEnd="@drawable/ic_calendar" android:focusable="false" android:hint="mm/dd/yyyy" android:minHeight="56dp" android:padding="16dp" android:textColor="#ffffff" android:textColorHint="#cbd5e1" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Intraoral Scan ID" android:textColor="#ffffff" android:textStyle="bold" android:layout_marginBottom="8dp" />
            <EditText android:id="@+id/etScanId" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" android:background="@drawable/bg_input_box_highlight" android:hint="Scan-2024-001" android:minHeight="56dp" android:padding="16dp" android:textColor="#ffffff" android:textColorHint="#cbd5e1" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gender" android:textColor="#ffffff" android:textStyle="bold" android:layout_marginBottom="8dp" />
             <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input_box_highlight">
                <Spinner android:id="@+id/spinnerGender" android:layout_width="match_parent" android:layout_height="56dp" android:backgroundTint="#ffffff" />
             </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/footerParams"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:id="@+id/btnPrevious" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Previous" android:textColor="#94a3b8" android:textSize="16sp" />
        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        <Button android:id="@+id/btnContinue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:backgroundTint="#0f766e" android:minWidth="120dp" android:text="Continue" android:textAllCaps="false" android:textColor="#ffffff" android:textSize="16sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
