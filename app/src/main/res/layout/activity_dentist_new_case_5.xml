<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".DentistNewCase5Activity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:text="New Case Entry"
            android:textColor="#94a3b8"
            android:textSize="16sp" />
        
        <Space android:layout_width="60dp" android:layout_height="24dp" />
    </LinearLayout>

    <!-- Progress Steps (Standardized 4 Steps) -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="24dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <!-- Step 1: Completed -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#10b981" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#10b981" />

        <!-- Step 2: Completed -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#10b981" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#10b981" />

        <!-- Step 3: Completed -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#10b981" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#10b981" />

        <!-- Step 4: Active -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:gravity="center"
            android:text="4"
            android:textColor="#10b981"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:fontFamily="sans-serif-medium"
        android:text="Review Case"
        android:textColor="#f8fafc"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressContainer" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/footerParams"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0f766e"
                android:backgroundTint="#15803d00"
                android:orientation="vertical"
                android:padding="24dp"
                 android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready for Smile Deficiency Analysis"
                    android:textColor="#2dd4bf"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal"/>
                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your inputs have been mapped to the Smile Deficiency framework. Please verify the clinical assessment before submission."
                    android:textColor="#5eead4"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Patient Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Patient Details"
                        android:textColor="#ffffff"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit"/>
                </LinearLayout>

                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Name" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryPatientName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jane Doe" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="DOB" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryPatientDob" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1989-05-12" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Gender" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryGender" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Female" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Scan Ref" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryScanId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="N/A" android:textColor="#2dd4bf" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
            
            <!-- Clinical Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Clinical Info"
                        android:textColor="#ffffff"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Deficiency" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryDeficiency" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Space Deficiency" android:textColor="#2dd4bf" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Treatment" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryTreatment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bridge" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Tooth" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryTooth" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#18, #19, #20" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Material" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryMaterial" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zirconia" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Files Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Files"
                        android:textColor="#ffffff"
                        android:textStyle="bold"
                        android:textSize="16sp"/>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Photos" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryPhotoCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 uploaded" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Face Photo"
                    android:textColor="#94a3b8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <ImageView
                    android:id="@+id/ivSummaryPhotoFace"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intraoral Photo"
                    android:textColor="#94a3b8"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <ImageView
                    android:id="@+id/ivSummaryPhotoIntra"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Scans" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvSummaryScanCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 uploaded" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footerParams"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btnPrevious"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Previous"
            android:textColor="#94a3b8"
            android:textSize="16sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#0f766e"
            android:fontFamily="sans-serif-medium"
            android:minWidth="120dp"
            android:text="Submit Case"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
