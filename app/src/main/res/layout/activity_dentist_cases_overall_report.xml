<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dentist_cases_overall_report"
    tools:context=".DentistCasesOverallReportActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#ffffff" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        
        <!-- Action Buttons -->
        <LinearLayout
            android:id="@+id/btnReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:backgroundTint="#ffffff"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
             <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_report"
                app:tint="#0f172a"
                android:layout_marginEnd="8dp"/>
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report"
                android:textColor="#0f172a"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnExport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:backgroundTint="#ffffff"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
             <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_export"
                app:tint="#0f172a"
                android:layout_marginEnd="8dp"/>
             <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Export"
                android:textColor="#0f172a"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>
        
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Created on Oct 24, 2023"
                android:textColor="#94a3b8"
                android:textSize="12sp"
                android:layout_marginBottom="24dp"/>

            <!-- 1. Aesthetic & AI Results Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aesthetic &amp; AI Analysis"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"/>

                 <!-- Aesthetic Metrics -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Aesthetic Symmetry" android:textColor="#64748b" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOverallSymmetry" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Optimal (95%)" android:textColor="#15803d" android:background="@drawable/bg_status_green" android:backgroundTint="#dcfce7" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Golden Ratio Match" android:textColor="#64748b" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOverallGoldenRatio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High (92%)" android:textColor="#15803d" android:background="@drawable/bg_status_green" android:backgroundTint="#dcfce7" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                 <!-- AI Scores -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Margin Clarity" android:textColor="#64748b" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grade A" android:textColor="#15803d" android:background="@drawable/bg_status_green" android:backgroundTint="#dcfce7" android:paddingHorizontal="8dp" android:paddingVertical="4dp" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Overall AI Grade" android:textColor="#64748b" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOverallAiGrade" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A+" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 2. Smile Deficiency Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#f8fafc"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smile Deficiency Addressed"
                    android:textColor="#0f766e"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvOverallDeficiencyReasoning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The multi-unit Bridge proposed plan restores occlusal vertical dimension and prevents further shifting of the abutments."
                    android:textColor="#1e293b"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Gingival Redness" android:textColor="#64748b" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvOverallRedness" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Normal" android:textColor="#10b981" android:textStyle="bold" android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Case Specifications Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Case Specifications"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prosthesis Type"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvOverallProsthesis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Crown"
                    android:textColor="#0f172a"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tooth Number"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvOverallTooth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14 (Upper Left First Molar)"
                    android:textColor="#0f172a"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Material"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zirconia (High Translucency)"
                    android:textColor="#0f172a"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shade"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A2"
                    android:textColor="#0f172a"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Case Timeline Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Case Timeline"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"/>

                 <!-- Step 1 -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_check_circle" app:tint="#15803d" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Case Created" android:textColor="#0f172a" android:textStyle="bold" android:textSize="14sp"/>
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Initial data entry and patient selection" android:textColor="#64748b" android:textSize="12sp"/>
                    </LinearLayout>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oct 24, 09:30 AM" android:textColor="#94a3b8" android:textSize="10sp"/>
                </LinearLayout>

                <!-- Step 2 -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_check_circle" app:tint="#15803d" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scans Uploaded" android:textColor="#0f172a" android:textStyle="bold" android:textSize="14sp"/>
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Intraoral scan and smile photos processed" android:textColor="#64748b" android:textSize="12sp"/>
                    </LinearLayout>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Oct 24, 09:45 AM" android:textColor="#94a3b8" android:textSize="10sp"/>
                </LinearLayout>

                <!-- Step 3 -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_layers" app:tint="#0f766e" android:layout_marginEnd="12dp"/> <!-- Reuse layers icon as loading/process -->
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Clinical Analysis" android:textColor="#0f766e" android:textStyle="bold" android:textSize="14sp"/>
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Processing crown parameters and occlusion" android:textColor="#64748b" android:textSize="12sp"/>
                    </LinearLayout>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="In Progress..." android:textColor="#0f766e" android:textSize="10sp"/>
                </LinearLayout>

                 <!-- Step 4 -->
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:layout_width="20dp" android:layout_height="20dp" android:background="@drawable/bg_icon_circle_green" android:backgroundTint="#e2e8f0" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dentist Review" android:textColor="#0f172a" android:textStyle="bold" android:textSize="14sp"/>
                         <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pending approval" android:textColor="#64748b" android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- 4. Medications & Care Tips Card (Initially Hidden or at bottom) -->
            <LinearLayout
                android:id="@+id/cardMedications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#f0fdfa"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medications &amp; Care Tips"
                    android:textColor="#0d9488"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRESCRIBED MEDICATIONS"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvOverallMedications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#1e293b"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARE INSTRUCTIONS"
                    android:textColor="#94a3b8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"/>
                <TextView
                    android:id="@+id/tvOverallCareTips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#1e293b"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
            
            <!-- Patient Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient Details"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="24dp"/>

                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:id="@+id/tvOverallPatientInitial"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_circle_green"
                        android:backgroundTint="#f0fdf4"
                        android:gravity="center"
                        android:text="S"
                        android:textColor="#16a34a"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginEnd="16dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvOverallPatientName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sarah Johnson"
                            android:textColor="#0f172a"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvOverallPatientInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID: P-2023001 • DOB: 12/05/1989"
                            android:textColor="#64748b"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>



            <!-- Complete Action Button -->
            <Button
                android:id="@+id/btnMarkComplete"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Mark as Completed"
                android:textColor="#ffffff"
                android:backgroundTint="#10b981"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
