<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_patient_dashboard"
    tools:context=".PatientPrivacyAndSecurityActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Privacy &amp; Policy"
            android:textColor="#f8fafc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Privacy Policy Content Card -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="12dp"
                 app:cardBackgroundColor="#ffffff"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="24dp"
                     android:orientation="vertical">
                     
                     <TextView 
                         android:layout_width="wrap_content" 
                         android:layout_height="wrap_content" 
                         android:text="Smile AI Privacy Policy" 
                         android:textColor="#0f172a" 
                         android:textSize="18sp" 
                         android:textStyle="bold" 
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="wrap_content" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="8dp"
                         android:text="Last Updated: March 2026" 
                         android:textColor="#94a3b8" 
                         android:textSize="12sp" 
                         android:fontFamily="sans-serif"/>

                     <View 
                         android:layout_width="match_parent" 
                         android:layout_height="1dp" 
                         android:background="#f1f5f9" 
                         android:layout_marginVertical="16dp"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:text="Your privacy is important to us. Smile AI is committed to protecting your personal and clinical data through advanced encryption and secure handling practices." 
                         android:textColor="#334155" 
                         android:textSize="14sp" 
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="16dp"
                         android:text="1. Data Collection" 
                         android:textColor="#0f172a" 
                         android:textSize="15sp" 
                         android:textStyle="bold" 
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="8dp"
                         android:text="We collect clinical findings, dental images, and personal identification to provide accurate AI-driven diagnostics and coordination with your dental professionals. All images are processed securely." 
                         android:textColor="#334155" 
                         android:textSize="14sp" 
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="16dp"
                         android:text="2. How We Use Data" 
                         android:textColor="#0f172a" 
                         android:textSize="15sp" 
                         android:textStyle="bold" 
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="8dp"
                         android:text="Your data is used to generate clinical reports, track healing progress, and facilitate appointments. AI models analyze your cases to provide preliminary findings which are then reviewed by licensed dentists." 
                         android:textColor="#334155" 
                         android:textSize="14sp" 
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="16dp"
                         android:text="3. Data Security" 
                         android:textColor="#0f172a" 
                         android:textSize="15sp" 
                         android:textStyle="bold" 
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="8dp"
                         android:text="We implement industry-standard AES-256 encryption for data at rest and TLS for data in transit. Access to clinical data is strictly restricted to your assigned dental professionals." 
                         android:textColor="#334155" 
                         android:textSize="14sp" 
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="16dp"
                         android:text="4. Your Rights" 
                         android:textColor="#0f172a" 
                         android:textSize="15sp" 
                         android:textStyle="bold" 
                         android:fontFamily="sans-serif"/>

                     <TextView 
                         android:layout_width="match_parent" 
                         android:layout_height="wrap_content" 
                         android:layout_marginTop="8dp"
                         android:text="You have the right to access, export, or delete your clinical history at any time. For data deletion requests, please contact our support team at support@smileai.com." 
                         android:textColor="#334155" 
                         android:textSize="14sp" 
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
