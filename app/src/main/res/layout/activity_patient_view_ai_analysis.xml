<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_patient_dashboard"
    tools:context=".PatientViewAiAnalysisActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#0f172a" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="AI Analysis"
            android:textColor="#f8fafc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Visualizer Card -->
             <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="280dp"
                 app:cardBackgroundColor="#00000000"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:layout_width="match_parent"
                     android:layout_height="match_parent"
                     android:background="@drawable/bg_card_visualizer"
                     android:padding="24dp">

                     <ImageView
                         android:layout_width="80dp"
                         android:layout_height="80dp"
                         android:src="@drawable/ic_scan_reticle"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintTop_toTopOf="parent"
                         app:layout_constraintBottom_toBottomOf="parent"
                         android:layout_marginBottom="40dp"/>

                     <LinearLayout
                         android:id="@+id/confidenceSection"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:orientation="vertical"
                         app:layout_constraintBottom_toBottomOf="parent">

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:orientation="horizontal"
                             android:gravity="center_vertical"
                             android:layout_marginBottom="8dp">

                             <ImageView
                                 android:layout_width="20dp"
                                 android:layout_height="20dp"
                                 android:src="@drawable/ic_sparkles_blue"
                                 app:tint="#60a5fa"/>

                             <TextView
                                 android:layout_width="0dp"
                                 android:layout_height="wrap_content"
                                 android:layout_weight="1"
                                 android:layout_marginStart="8dp"
                                 android:text="AI Confidence"
                                 android:textColor="#f8fafc"
                                 android:textSize="14sp"
                                 android:fontFamily="sans-serif"/>

                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:id="@+id/tvConfidence"
                                 android:text="94%"
                                 android:textColor="#60a5fa"
                                 android:textStyle="bold"
                                 android:textSize="14sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>

                         <ProgressBar
                             android:id="@+id/pbConfidence"
                             android:layout_width="match_parent"
                             android:layout_height="6dp"
                             android:progressDrawable="@drawable/bg_progress_bar_blue"
                             android:progress="94"
                             android:max="100"
                             style="?android:attr/progressBarStyleHorizontal"/>

                     </LinearLayout>

                 </androidx.constraintlayout.widget.ConstraintLayout>

             </androidx.cardview.widget.CardView>


            <!-- Key Findings -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="24dp"
                 app:cardBackgroundColor="#ffffff"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="24dp"
                     android:orientation="vertical">

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="center_vertical"
                         android:orientation="horizontal">

                         <TextView
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:text="Key Findings"
                             android:textColor="#0f172a"
                             android:textSize="18sp"
                             android:textStyle="bold"
                             android:fontFamily="sans-serif"/>
                         
                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:text="Analysis Complete"
                             android:textColor="#10b981"
                             android:textSize="12sp"
                             android:background="@drawable/bg_alert_success_light"
                             android:paddingHorizontal="10dp"
                             android:paddingVertical="4dp"
                             android:fontFamily="sans-serif"/>
                     </LinearLayout>

                     <!-- Finding 1 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:background="@drawable/bg_alert_error_light"
                         android:padding="16dp"
                         android:orientation="horizontal">
                         
                         <ImageView
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_warning_triangle"
                             app:tint="#ef4444"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="12dp"
                             android:orientation="vertical">
                             
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:id="@+id/tvFinding1Title"
                                 android:text="Structural Damage Detected"
                                 android:textColor="#991b1b"
                                 android:textStyle="bold"
                                 android:textSize="14sp"
                                 android:fontFamily="sans-serif"/>

                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:id="@+id/tvFinding1Desc"
                                 android:text="Significant wear on Upper Right Molar (#3) requiring intervention."
                                 android:textColor="#b91c1c"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>

                         </LinearLayout>
                     </LinearLayout>

                      <!-- Finding 2 -->
                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="12dp"
                         android:background="@drawable/bg_card_white"
                         android:padding="16dp"
                         android:orientation="horizontal">

                         <ImageView
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_check_circle_green"
                             app:tint="#10b981"/>

                         <LinearLayout
                             android:layout_width="match_parent"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="12dp"
                             android:orientation="vertical">

                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Healthy Gum Tissue"
                                 android:textColor="#0f172a"
                                 android:textStyle="bold"
                                 android:textSize="14sp"
                                 android:fontFamily="sans-serif"/>

                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:text="Surrounding gingival tissue appears healthy with no inflammation."
                                 android:textColor="#64748b"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>

                         </LinearLayout>
                     </LinearLayout>

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Treatment Summary Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#ffffff"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI Treatment Summary"
                        android:textColor="#0f172a"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="16dp"/>

                    <!-- Recommended Action -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOMMENDED ACTION"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvPatientRecommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Prosthetic bridge recommended for restoration."
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <!-- AI Explanation -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI EXPLANATION"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvPatientExplanation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="The AI identifies a structural deficiency that requires a multi-unit approach to ensure long-term stability and bite alignment."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                    <!-- Risk Analysis -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RISK ANALYSIS"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvRiskAnalysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Moderate structural risk detected."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                    <!-- Aesthetic Prognosis -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AESTHETIC PROGNOSIS"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvAestheticPrognosis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Positive results with regular monitoring."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                    <!-- Placement Strategy -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PLACEMENT STRATEGY"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvPlacementStrategy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Standard clinical placement protocol."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#f1f5f9"
                        android:layout_marginBottom="16dp"/>

                    <!-- Aesthetic Metrics -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AESTHETIC METRICS"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Symmetry Score" android:textColor="#475569" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvPatientSymmetry" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="92%" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Golden Ratio Match" android:textColor="#475569" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvPatientGoldenRatio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.618" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Medical Recommendations Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="#ffffff"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Medical Recommendations"
                        android:textColor="#0f172a"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif"
                        android:layout_marginBottom="16dp"/>

                    <!-- Medications -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRESCRIBED MEDICATIONS"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvPatientMedications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Standard oral care suggested."
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <!-- Care Instructions -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CARE INSTRUCTIONS"
                        android:textColor="#64748b"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvPatientCareTips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Maintain standard 2x daily brushing and flossing."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0f172a"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#cbd5e1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navCases"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_cases"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cases"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_reports"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Reports"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Profile"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
