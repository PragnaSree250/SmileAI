<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dentist_apply_and_preview"
    tools:context=".DentistApplyAndPreviewActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                android:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Clinical Summary"
            android:textColor="#f8fafc"
            android:textSize="20sp"
            android:textStyle="bold" />
        
        <Button
            android:id="@+id/btnFinalizeReport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#0f766e"
            android:fontFamily="sans-serif-medium"
            android:text="Finalize &amp; Report"
            android:textAllCaps="false"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:minHeight="40dp"
            android:padding="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            
            <!-- Comparison Mode Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#1e293b"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Professional Comparison Mode"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchComparison"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="#10b981"
                    app:trackTint="#334155"/>
            </LinearLayout>

            <!-- Visualization Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="2dp"
                android:layout_marginBottom="24dp">
                
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    
                    <!-- Original Image Layer -->
                    <ImageView
                        android:id="@+id/ivPreviewOriginal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_upload"
                        app:tint="#475569"
                        android:alpha="0.3"/>

                    <!-- Simulation Layer (Overlay) -->
                    <ImageView
                        android:id="@+id/ivPreviewSimulation"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_tooth_visual"
                        app:tint="#38bdf8"
                        android:visibility="gone"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="16dp"
                        android:background="#800f172a"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp">
                        <TextView
                            android:id="@+id/tvViewLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INITIAL SCAN"
                            android:textColor="#f8fafc"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Case Details Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Case Details"
                    android:textColor="#f8fafc"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Patient" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvClinicalPatientName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loading..." android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="No. of Teeth" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvClinicalTeethCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
                 <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Material" android:textColor="#94a3b8"/>
                    <TextView android:id="@+id/tvClinicalMaterial" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loading..." android:textColor="#f1f5f9" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- View Options Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Options"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp"/>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show Gingiva"
                    android:checked="true"
                    android:textColor="#334155"
                    android:buttonTint="#0f766e"
                    android:layout_marginBottom="8dp"/>
                
                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show Antagonist"
                    android:checked="true"
                    android:textColor="#334155"
                    android:buttonTint="#0f766e"
                    android:layout_marginBottom="8dp"/>

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wireframe Mode"
                    android:textColor="#334155"
                    android:buttonTint="#0f766e"/>

            </LinearLayout>

            <!-- Opacity Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Opacity"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Restoration Opacity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                     android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Restoration Findings" android:textColor="#334155" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#0f172a" android:textSize="12sp"/>
                </LinearLayout>
                <SeekBar
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="#0f172a"
                    android:thumbTint="#0f172a"
                    android:layout_marginBottom="24dp"/>

                 <!-- Original Scan Opacity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                     android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Initial Scan" android:textColor="#334155" android:textStyle="bold" android:textSize="12sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50%" android:textColor="#0f172a" android:textSize="12sp"/>
                </LinearLayout>
                <SeekBar
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50"
                    android:progressTint="#0f172a"
                    android:thumbTint="#0f172a"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
