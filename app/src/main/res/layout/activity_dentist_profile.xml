<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dentist_profile"
    tools:context=".DentistProfileActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                android:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="Smile AI"
            android:textColor="#f8fafc"
            android:textSize="20sp"
            android:textStyle="bold" />
        
        <ImageView
             android:id="@+id/btnNotifications"
             android:layout_width="24dp"
             android:layout_height="24dp"
             android:src="@drawable/ic_notification"
             app:tint="#f8fafc"
             android:layout_marginEnd="16dp"
             android:clickable="true"
             android:focusable="true"/>
          <ImageView
             android:id="@+id/btnMenu"
             android:layout_width="24dp"
             android:layout_height="24dp"
             android:src="@drawable/ic_menu"
             app:tint="#f8fafc"
             android:clickable="true"
             android:focusable="true"/>
        
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textColor="#f8fafc"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <!-- Profile Image Section -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                
                <ImageView
                     android:id="@+id/ivProfilePhoto"
                     android:layout_width="120dp"
                     android:layout_height="120dp"
                     android:scaleType="centerCrop"
                     android:src="@drawable/ic_profile_placeholder" 
                     app:tint="#64748b"
                     android:layout_gravity="center"/>

                <ImageButton
                    android:id="@+id/btnUploadPhoto"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_camera"
                    android:background="@drawable/bg_icon_teal"
                    android:padding="8dp"
                    android:layout_gravity="bottom|end"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Sarah Smith"
                android:textColor="#f8fafc"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvProfileSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prosthodontist"
                android:textColor="#94a3b8"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDentistId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading ID..."
                android:textColor="#38bdf8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <!-- Personal Information Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_surface_card"
                android:backgroundTint="#ffffff"
                android:orientation="vertical"
                android:padding="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personal Information"
                    android:textColor="#0f172a"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp"/>

                <!-- First Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="First Name"
                    android:textColor="#64748b"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etFirstName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="Sarah"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Last Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last Name"
                    android:textColor="#64748b"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etLastName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="Smith"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#64748b"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="sarah.smith@clinic.com"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="textEmailAddress"
                    android:enabled="false"/> <!-- Email is usually fixed -->

                <!-- Phone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textColor="#64748b"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="+1 (555) 123-4567"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="24dp"
                    android:inputType="phone"/>

                 <!-- Clinic Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clinic Address"
                    android:textColor="#64748b"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etClinicAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:text="123 Dental Ave, Suite 100"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="32dp"
                    android:inputType="textPostalAddress"/>

                <Button
                    android:id="@+id/btnSaveChanges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Changes"
                    android:textAllCaps="false"
                    android:backgroundTint="#0f766e"
                    android:textColor="#ffffff"
                    android:paddingVertical="12dp"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delete Account"
                    android:textAllCaps="false"
                    android:backgroundTint="#dc2626"
                    android:textColor="#ffffff"
                    android:paddingVertical="12dp"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
