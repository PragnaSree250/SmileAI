<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".DentistFinalizedReportActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                android:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:text="Finalized Report"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Space
            android:layout_width="60dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/footerActions"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Report Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1e293b"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Diagnostic &amp; Treatment Summary"
                        android:textColor="#f8fafc"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Primary Diagnosis -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIMARY DIAGNOSIS"
                        android:textColor="#94a3b8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_check_circle_outline"
                            app:tint="#2dd4bf"/>
                        <TextView
                            android:id="@+id/tvDeficiencyAddressed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Space Deficiency Resolved"
                            android:textColor="#2dd4bf"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Recommended Treatment -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECOMMENDED TREATMENT"
                        android:textColor="#94a3b8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvFinalRecommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="Proceed with Zirconia Bridge for teeth #18, #19, #20."
                        android:textColor="#f8fafc"
                        android:textSize="15sp"
                        android:textStyle="italic"/>

                    <!-- Clinical Rationale -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLINICAL RATIONALE"
                        android:textColor="#94a3b8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvReasoning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:text="AI analysis confirms that a zirconia-based bridge is the optimal solution..."
                        android:textColor="#cbd5e1"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>

                    <!-- Secondary Insights -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RISK ANALYSIS"
                                android:textColor="#94a3b8"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvRiskAnalysis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Low"
                                android:textColor="#e2e8f0"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PROGNOSIS"
                                android:textColor="#94a3b8"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvAestheticPrognosis"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Stable"
                                android:textColor="#e2e8f0"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="8dp"/>

                    <!-- Clinical Findings Summary -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CLINICAL FINDINGS SUMMARY"
                        android:textColor="#94a3b8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Hyperdontia" android:textColor="#e2e8f0" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvFinalHyperdontia" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="None" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Aesthetic Symmetry" android:textColor="#e2e8f0" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvFinalSymmetry" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Optimal" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Golden Ratio" android:textColor="#e2e8f0" android:textSize="13sp"/>
                        <TextView android:id="@+id/tvFinalGoldenRatio" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.618 Match" android:textColor="#10b981" android:textStyle="bold" android:textSize="13sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#334155"
                        android:layout_marginVertical="16dp"/>

                    <!-- Medical Prescriptions -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRESCRIBED MEDICATIONS"
                        android:textColor="#2dd4bf"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvMedications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No medications prescribed."
                        android:textColor="#f8fafc"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POST-CARE INSTRUCTIONS"
                        android:textColor="#2dd4bf"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvCareInstructions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Standard oral hygiene maintenance suggested."
                        android:textColor="#f8fafc"
                        android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Footer Actions -->
    <LinearLayout
        android:id="@+id/footerActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0f172a"
        android:padding="24dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnDownloadReport"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:backgroundTint="#334155"
            android:text="Download"
            android:textColor="#ffffff"
            android:textAllCaps="false"
            android:layout_marginEnd="16dp"/>

        <Button
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:backgroundTint="#10b981"
            android:text="Done"
            android:textColor="#ffffff"
            android:textAllCaps="false"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
