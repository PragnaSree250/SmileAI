<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvCaseInitial"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_teal"
        android:gravity="center"
        android:text="S"
        android:textColor="#ffffff"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCasePatientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Sarah J."
            android:textColor="#f8fafc"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCaseDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crown #14"
            android:textColor="#94a3b8"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCaseStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status_blue"
        android:text="In Progress"
        android:textColor="#ffffff"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"/>
</LinearLayout>
