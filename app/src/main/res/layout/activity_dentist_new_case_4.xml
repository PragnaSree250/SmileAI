<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".DentistNewCase4Activity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                app:tint="#ffffff" />
        </LinearLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:text="New Case Entry"
            android:textColor="#94a3b8"
            android:textSize="16sp" />
        
        <Space android:layout_width="60dp" android:layout_height="24dp" />
    </LinearLayout>

    <!-- Progress Steps (Standardized 4 Steps) -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="24dp"
        android:paddingTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/topBar">

        <!-- Step 1: Completed -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#10b981" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#10b981" />

        <!-- Step 2: Completed -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:padding="6dp"
            android:src="@drawable/ic_check"
            app:tint="#10b981" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#10b981" />

        <!-- Step 3: Active -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_circle_green_light"
            android:gravity="center"
            android:text="3"
            android:textColor="#10b981"
            android:textStyle="bold" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#334155" />

        <!-- Step 4: Inactive -->
        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_input_box"
            android:gravity="center"
            android:text="4"
            android:textColor="#64748b" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:fontFamily="sans-serif-medium"
        android:text="Upload Files"
        android:textColor="#f8fafc"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressContainer" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@+id/footerParams"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Full Face Smile (Frontal)" android:textColor="#ffffff" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <LinearLayout android:id="@+id/layoutUploadFace" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="120dp" android:background="@drawable/bg_upload_area" android:layout_marginBottom="24dp" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                <ImageView android:id="@+id/ivPreviewFace" android:layout_width="match_parent" android:layout_height="200dp" android:scaleType="centerInside" android:visibility="gone" android:layout_marginBottom="8dp"/>
                <ImageView android:id="@+id/ivUploadIcon" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_upload"/>
                <TextView android:id="@+id/tvUploadText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Click to capture/upload" android:textColor="#2dd4bf" android:textStyle="bold" android:layout_marginTop="8dp"/>
                <TextView android:id="@+id/tvSupportedFormat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Supported format: .png, .jpg (Max 10MB)" android:textColor="#94a3b8" android:textSize="12sp" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Intraoral Frontal (Rest)" android:textColor="#ffffff" android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <LinearLayout android:id="@+id/layoutUploadIntra" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="120dp" android:background="@drawable/bg_upload_area" android:layout_marginBottom="24dp" android:gravity="center" android:orientation="vertical" android:padding="8dp">
                <ImageView android:id="@+id/ivPreviewIntra" android:layout_width="match_parent" android:layout_height="200dp" android:scaleType="centerInside" android:visibility="gone" android:layout_marginBottom="8dp"/>
                <ImageView android:id="@+id/ivUploadIconIntra" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_upload"/>
                <TextView android:id="@+id/tvUploadTextIntra" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Click to capture/upload" android:textColor="#2dd4bf" android:textStyle="bold" android:layout_marginTop="8dp"/>
            </LinearLayout>
             
             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shade Selection" android:textColor="#ffffff" android:textSize="18sp" android:textStyle="bold" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>
             <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="4" android:useDefaultMargins="true">
                <TextView android:id="@+id/shadeA1" android:text="A1" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeA2" android:text="A2" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeA3" android:text="A3" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeA35" android:text="A3.5" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeB1" android:text="B1" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeB2" android:text="B2" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeC1" android:text="C1" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
                <TextView android:id="@+id/shadeBL1" android:text="BL1" android:background="@drawable/bg_input_box" android:padding="16dp" android:textColor="#ffffff" android:layout_columnWeight="1" android:gravity="center" android:layout_margin="4dp"/>
             </GridLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout android:id="@+id/footerParams" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="24dp" app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:id="@+id/btnPrevious" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Previous" android:textColor="#94a3b8" android:textSize="16sp" />
        <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        <Button android:id="@+id/btnContinue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:backgroundTint="#0f766e" android:minWidth="120dp" android:text="Continue" android:textAllCaps="false" android:textColor="#ffffff" android:textSize="16sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
