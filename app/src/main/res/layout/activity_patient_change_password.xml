<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_patient_dashboard"
    tools:context=".PatientChangePasswordActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#0f172a" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Change Password"
            android:textColor="#f8fafc"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:cardBackgroundColor="#f8fafc"
                 app:cardCornerRadius="16dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="16dp"
                     android:gravity="center_vertical"
                     android:orientation="horizontal">
                     
                     <ImageView
                         android:layout_width="24dp"
                         android:layout_height="24dp"
                         android:src="@drawable/ic_lock_outline"
                         app:tint="#64748b"/>
                     
                     <TextView
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_weight="1"
                         android:layout_marginStart="16dp"
                         android:text="Choose a strong password that you don't use for other accounts. We recommend using a password manager."
                         android:textColor="#64748b"
                         android:textSize="12sp"
                         android:lineHeight="18sp"
                         android:fontFamily="sans-serif"/>
                 </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Current Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Current Password"
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">
                
                <EditText
                    android:id="@+id/etCurrentPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Enter current password"
                    android:inputType="textPassword"
                    android:textColor="#0f172a"
                    android:textColorHint="#94a3b8"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>
                
                <ImageView
                    android:id="@+id/btnToggleCurrent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_eye_gray"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- New Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="New Password"
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">
                
                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Enter new password"
                    android:inputType="textPassword"
                    android:textColor="#0f172a"
                    android:textColorHint="#94a3b8"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>
                
                <ImageView
                    android:id="@+id/btnToggleNew"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_eye_gray"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Confirm Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Confirm New Password"
                android:textColor="#94a3b8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"/>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">
                
                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Confirm new password"
                    android:inputType="textPassword"
                    android:textColor="#0f172a"
                    android:textColorHint="#94a3b8"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"/>
                
                <ImageView
                    android:id="@+id/btnToggleConfirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_eye_gray"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Update Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_button_gradient"
                android:text="Update Password"
                android:textColor="#ffffff"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:fontFamily="sans-serif"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
