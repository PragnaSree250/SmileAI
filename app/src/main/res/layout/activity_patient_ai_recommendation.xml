<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_patient_dashboard"
    tools:context=".PatientAiRecommendationActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_white"
            android:padding="10dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#0f172a" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Recommendation"
            android:textColor="#f8fafc"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Best Match Card -->
             <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 app:cardBackgroundColor="#00000000"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <androidx.constraintlayout.widget.ConstraintLayout
                     android:layout_width="match_parent"
                     android:layout_height="match_parent"
                     android:background="@drawable/bg_card_best_match"
                     android:padding="24dp">

                     <TextView
                         android:id="@+id/badgeBestMatch"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:text="Best Match"
                         android:textColor="#ffffff"
                         android:textSize="12sp"
                         android:background="@drawable/bg_badge_best_match"
                         android:paddingHorizontal="10dp"
                         android:paddingVertical="4dp"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintTop_toTopOf="parent"
                         android:fontFamily="sans-serif"/>

                     <ImageView
                         android:layout_width="48dp"
                         android:layout_height="48dp"
                         android:src="@drawable/ic_check_circle_white_outline"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintTop_toTopOf="parent"/>

                     <TextView
                         android:id="@+id/textTitle"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:text="Ceramic Crown"
                         android:textColor="#ffffff"
                         android:textSize="24sp"
                         android:textStyle="bold"
                         app:layout_constraintTop_toBottomOf="@id/badgeBestMatch"
                         app:layout_constraintStart_toStartOf="parent"
                         android:fontFamily="sans-serif"/>

                     <TextView
                         android:id="@+id/textSubtitle"
                         android:layout_width="wrap_content"
                         android:layout_height="wrap_content"
                         android:text="Zirconia-based material"
                         android:textColor="#fff1f2"
                         android:textSize="14sp"
                         app:layout_constraintTop_toBottomOf="@id/textTitle"
                         app:layout_constraintStart_toStartOf="parent"
                         android:fontFamily="sans-serif"/>

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="32dp"
                         android:orientation="horizontal"
                         app:layout_constraintTop_toBottomOf="@id/textSubtitle">

                         <!-- Durability -->
                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Durability"
                                 android:textColor="#1f2937"
                                 android:textSize="12sp"
                                 android:textStyle="bold"
                                 android:fontFamily="sans-serif"/>
                             <LinearLayout
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:orientation="horizontal">
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:src="@drawable/ic_circle_filled_white"/> <!-- 5/5 -->
                             </LinearLayout>
                         </LinearLayout>

                         <!-- Esthetics -->
                         <LinearLayout
                             android:layout_width="0dp"
                             android:layout_height="wrap_content"
                             android:layout_weight="1"
                             android:orientation="vertical">
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Esthetics"
                                 android:textColor="#1f2937"
                                 android:textSize="12sp"
                                 android:textStyle="bold"
                                 android:fontFamily="sans-serif"/>
                             <LinearLayout
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:layout_marginTop="4dp"
                                 android:orientation="horizontal">
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:layout_marginEnd="4dp" android:src="@drawable/ic_circle_filled_white"/>
                                 <ImageView android:layout_width="8dp" android:layout_height="8dp" android:src="@drawable/ic_circle_filled_white_alpha"/> <!-- 4/5 -->
                             </LinearLayout>
                         </LinearLayout>

                     </LinearLayout>

                 </androidx.constraintlayout.widget.ConstraintLayout>
             </androidx.cardview.widget.CardView>

            <!-- Explanation Card -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="24dp"
                 app:cardBackgroundColor="#ffffff"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="24dp"
                     android:orientation="vertical">

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="center_vertical"
                         android:orientation="horizontal">
                         
                         <ImageView
                             android:layout_width="24dp"
                             android:layout_height="24dp"
                             android:src="@drawable/ic_info_circle"
                             app:tint="#3b82f6"/>

                         <TextView
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="12dp"
                             android:text="Why this option?"
                             android:textColor="#0f172a"
                             android:textSize="18sp"
                             android:textStyle="bold"
                             android:fontFamily="sans-serif"/>
                     </LinearLayout>

                     <TextView
                         android:id="@+id/textExplanation"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:text="Based on the AI analysis of your bite pressure and aesthetic requirements, a Zirconia crown offers the best balance of strength and natural appearance for a molar tooth."
                         android:textColor="#64748b"
                         android:textSize="14sp"
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:orientation="vertical">
                         
                         <!-- Bullet 1 -->
                         <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                             <ImageView android:layout_width="6dp" android:layout_height="6dp" android:src="@drawable/bg_icon_circle_blue" app:tint="#3b82f6"/>
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Superior durability for chewing" android:textColor="#475569" android:textSize="13sp" android:fontFamily="sans-serif"/>
                         </LinearLayout>
                         <!-- Bullet 2 -->
                         <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                             <ImageView android:layout_width="6dp" android:layout_height="6dp" android:src="@drawable/bg_icon_circle_blue" app:tint="#3b82f6"/>
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Natural color matching" android:textColor="#475569" android:textSize="13sp" android:fontFamily="sans-serif"/>
                         </LinearLayout>
                         <!-- Bullet 3 -->
                         <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                             <ImageView android:layout_width="6dp" android:layout_height="6dp" android:src="@drawable/bg_icon_circle_blue" app:tint="#3b82f6"/>
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Biocompatible material" android:textColor="#475569" android:textSize="13sp" android:fontFamily="sans-serif"/>
                         </LinearLayout>
                          <!-- Bullet 4 -->
                         <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                             <ImageView android:layout_width="6dp" android:layout_height="6dp" android:src="@drawable/bg_icon_circle_blue" app:tint="#3b82f6"/>
                             <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Long-term stability" android:textColor="#475569" android:textSize="13sp" android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </LinearLayout>

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Doctor Note Card -->
            <androidx.cardview.widget.CardView
                 android:layout_width="match_parent"
                 android:layout_height="wrap_content"
                 android:layout_marginTop="24dp"
                 app:cardBackgroundColor="#ffffff"
                 app:cardCornerRadius="24dp"
                 app:cardElevation="0dp">

                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:padding="24dp"
                     android:orientation="vertical">

                     <LinearLayout
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:gravity="center_vertical"
                         android:orientation="horizontal">

                         <ImageView
                             android:layout_width="40dp"
                             android:layout_height="40dp"
                             android:src="@drawable/ic_person"
                             app:tint="#cbd5e1"/>

                         <LinearLayout
                             android:layout_width="wrap_content"
                             android:layout_height="wrap_content"
                             android:layout_marginStart="12dp"
                             android:orientation="vertical">
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Dr. Smith"
                                 android:textColor="#0f172a"
                                 android:textSize="16sp"
                                 android:textStyle="bold"
                                 android:fontFamily="sans-serif"/>
                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="Prosthodontist"
                                 android:textColor="#64748b"
                                 android:textSize="12sp"
                                 android:fontFamily="sans-serif"/>
                         </LinearLayout>
                     </LinearLayout>

                     <TextView
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:text="&quot;I agree with the AI assessment. The Zirconia option will provide the best longevity for this specific tooth position.&quot;"
                         android:textColor="#475569"
                         android:textSize="14sp"
                         android:fontStyle="italic"
                         android:lineSpacingExtra="4dp"
                         android:fontFamily="sans-serif"/>

                 </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0f172a"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navCases"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_cases"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Cases"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_reports"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Reports"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>

        <LinearLayout
             android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                app:tint="#cbd5e1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Profile"
                android:textColor="#cbd5e1"
                android:textSize="12sp"
                android:fontFamily="sans-serif"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
